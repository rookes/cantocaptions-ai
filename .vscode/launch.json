{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Bluey from Debug",
            "type": "debugpy",
            "request": "launch",
            "module": "cantoqwenx",
            "args": ["bluey_test.wav", "--load_debug_dir", "debug/"]
        },
        {
            "name": "Run Bluey Test",
            "type": "debugpy",
            "request": "launch",
            "module": "cantoqwenx",
            "args": ["bluey_test.wav", "--debug_dir", "debug/"]
        },
        {
            "name": "Run Bluey Test With Log File",
            "type": "debugpy",
            "request": "launch",
            "module": "cantoqwenx",
            "args": ["bluey_test.wav", "--debug_dir", "debug/", "--log_file", "cantoqwenx.log"]
        },
        {
            "name": "Run Bluey Test With Ensemble",
            "type": "debugpy",
            "request": "launch",
            "module": "cantoqwenx",
            "args": ["bluey_test.wav", "--load_debug_dir", "debug/", "--debug_dir", "debug/", "--ensemble_model", "whisper", "--llm_correction"]
        },
        {
            "name": "Spirited Away",
            "type": "debugpy",
            "request": "launch",
            "module": "cantoqwenx",
            "args": ["\"E:\\[Trix] Spirited Away (2001) (BD 1080p AV1) [74611FA7].mkv\"", "--load_debug_dir", "debug/", "--log_file", "cantoqwenx.log"]
        },
        {
            "name": "Run Bluey (no MBRFRMR)",
            "type": "debugpy",
            "request": "launch",
            "module": "cantoqwenx",
            "args": ["bluey_test_vocals.wav", "--vocal_isolation_method=none"]
        },
        {
            "name": "Run custom file",
            "type": "debugpy",
            "request": "launch",
            "module": "cantoqwenx",
            "args": ["316 - The Southern Raiders_vocals.wav"]
        },
        {
            "name": "Run test.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}"
        }
    ]
}